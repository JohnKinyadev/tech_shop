TECH_SHOP_ENVIRONMENT=development
TECH_SHOP_DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5433/tech_shop_system
TECH_SHOP_JWT_SECRET_KEY=replace-with-a-long-random-secret
TECH_SHOP_JWT_ALGORITHM=HS256
TECH_SHOP_ACCESS_TOKEN_MINUTES=60
TECH_SHOP_REFRESH_TOKEN_DAYS=7
